{
  "name": "digipe",
  "version": "1.0.0",
  "description": "Full-stack payment application with React, Node, Express and MongoDB",
  "main": "server/src/server.js",
  "scripts": {
    "start": "node server/src/server.js",
    "postinstall": "npm install --prefix server",
    "install-all": "npm install --prefix client && npm install --prefix server",
    "client": "npm start --prefix client",
    "server": "npm run dev --prefix server",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "test": "npm test --prefix client",
    "lint": "npm run lint --prefix client && npm run lint --prefix server"
  },
  "keywords": [
    "payment",
    "banking",
    "react",
    "node",
    "mongodb"
  ],
  "author": "Harshil Joshi",
  "license": "",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.x"
  },
  "type": "module"
}